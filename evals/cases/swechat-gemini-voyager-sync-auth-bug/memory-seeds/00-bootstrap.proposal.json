      {
        "id": "claim.repo_identity",
        "kind": "fact",
        "text": "Gemini Voyager is a GPL-3.0 browser extension that augments Google Gemini and AI Studio with folders, prompt vault, timeline navigation, chat export, cloud sync, formula copy, visual effects, and related productivity tools.",
