      {
        "id": "claim.repo_constraints",
        "kind": "requirement",
        "text": "Repository guidance requires no `any`, `StorageService` instead of direct `chrome.storage` in UI components, `LoggerService` instead of production `console.log`, `gv-` prefixes for CSS injected into Gemini DOM, all 10 locales updated for i18n key changes, and no direct edits under `dist_*` folders.",
        "truth": "source_verified",
        "intent": "intended",
        "code_anchors": [
          {
            "file": "CLAUDE.md"
          }
        ],
        "about": "component.repository"
      },
