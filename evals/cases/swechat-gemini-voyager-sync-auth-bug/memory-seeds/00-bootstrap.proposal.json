        "id": "claim.repo_commands",
        "kind": "fact",
        "text": "The documented local workflow uses Bun: install with `bun install`, develop with `bun run dev:chrome` or browser variants, verify with `bun run typecheck`, `bun run lint`, `bun run test`, and build with `bun run build:chrome` or browser variants.",
        "truth": "source_verified",
        "intent": "intended",
        "code_anchors": [
